# ═════════════════════════════════════════════════════════════════════
# RespondaCare Environment Variables — Template Config
# Copy this file to `.env` and fill in your actual credentials.
# ═════════════════════════════════════════════════════════════════════

# Supabase database endpoint URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase public anonymous API key (safe to include in bundle)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-payload-here.your-signature
